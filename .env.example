# ===========================================
# 設備予約システム - 環境変数テンプレート
# ===========================================
# このファイルをコピーして .env にリネームし、各値を設定してください。
# .env はgitignoreされているのでリポジトリにはコミットされません。
# Cloudflare Pages にデプロイする際は、Cloudflare ダッシュボードで環境変数を設定してください。
# ===========================================

# --- Supabase ---
# Supabase ダッシュボード > Project Settings > API で確認できます。
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# 「Publishable key」（旧: anon key）
PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"
# 「Secret key」（旧: service_role key） - サーバーサイドのみ使用（絶対に公開しないこと）
# Supabase ダッシュボード > Project Settings > API > Secret keys
SUPABASE_SERVICE_ROLE_KEY="your-supabase-secret-key-here"

# --- Google Calendar API ---
# Google Cloud Console で OAuth 2.0 クライアントID を作成し、
# Client ID と Client Secret を設定してください。
# ※ 未設定の場合、カレンダー同期はスキップされます（予約機能自体は動作します）。
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
