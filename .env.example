# ===========================================
# 設備予約システム - 環境変数テンプレート
# ===========================================
# このファイルをコピーして .env にリネームし、各値を設定してください。
# .env はgitignoreされているのでリポジトリにはコミットされません。
# Cloudflare PagesにデプロイするDocker自は、Cloudflareダッシュボードで環境変数を設定してください。
# ===========================================

# --- Supabase ---
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"

# --- Google Calendar API ---
# Google Cloud Console で OAuth 2.0 クライアントID を作成し、
# Client ID と Client Secret を設定してください。
# ※ 未設定の場合、カレンダー同期はスキップされます（予約機能自体は動作します）。
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
