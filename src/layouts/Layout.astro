---
/**
 * 共通レイアウトコンポーネント
 *
 * - HTML シェル（head / meta / SEO）
 * - Google Fonts（Inter, Noto Sans JP）の読み込み
 * - グローバルCSS（Tailwind v4）の読み込み
 * - テーマ初期化（FOUC 防止のインラインスクリプト）
 * - Supabase 設定のクライアント公開
 * - ヘッダーの組み込み
 */
import Header from '../components/Header.astro';
import { SUPABASE_CONFIG } from '../lib/supabase';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  showHeader?: boolean;
}

const {
  title = '設備予約 | Equipment Reservation',
  description = '社内設備予約管理システム',
  showHeader = true,
} = Astro.props;

const member = Astro.locals.member;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!--
      テーマ初期化スクリプト（FOUC防止）
      - localStorage の値を即時に <html> へ反映して、白→黒のチラつきを防ぐ
      - 初回アクセス時はデフォルト "light" を適用
    -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>

  <body class="min-h-dvh">
    <!--
      Supabase 設定をグローバル変数として公開
      - Header のログアウトボタンや、Preactコンポーネント内で使用
    -->
    <script
      define:vars={{
        supabaseUrl: SUPABASE_CONFIG.url,
        supabaseKey: SUPABASE_CONFIG.anonKey,
      }}
    >
      window.__SUPABASE_URL__ = supabaseUrl;
      window.__SUPABASE_ANON_KEY__ = supabaseKey;
    </script>

    {showHeader && member && <Header memberName={member.name} />}
    <main>
      <slot />
    </main>
  </body>
</html>
