---
/**
 * ヘッダーコンポーネント
 *
 * - アプリタイトル（ロゴ + テキスト）
 * - テーマ切替ボタン（Light ↔ Dark）
 * - ログインユーザー名 + アバター
 * - 管理者の場合: ⚙️ システム管理 リンク
 * - ログアウトボタン
 */
interface Props {
  memberName: string;
  memberRole?: 'admin' | 'user';
}

const { memberName, memberRole } = Astro.props;
const isAdmin = memberRole === 'admin';
---

<header
  id="app-header"
  class="sticky top-0 z-50"
  style="
    border-bottom: 1px solid var(--theme-header-border);
    background: var(--theme-header-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  "
>
  <div class="mx-auto flex h-14 max-w-screen-2xl items-center justify-between px-4 sm:px-6">

    <!-- アプリタイトル -->
    <a
      href="/"
      class="flex items-center gap-2.5 text-lg font-semibold tracking-tight no-underline"
      style="color: var(--theme-text);"
    >
      <div
        class="flex h-8 w-8 items-center justify-center rounded-lg"
        style="background: oklch(0.55 0.21 250 / 0.12);"
      >
        <svg class="h-[18px] w-[18px] text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
      </div>
      <span class="hidden sm:inline">設備予約</span>
    </a>

    <!-- 右側: ナビゲーション -->
    <div class="flex items-center gap-2 sm:gap-3">

      <!-- テーマ切替ボタン -->
      <button
        id="theme-toggle-btn"
        class="nav-btn"
        title="テーマ切替"
        aria-label="テーマを切り替える"
      >
        <svg id="icon-moon" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg id="icon-sun" class="h-4 w-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      </button>

      <!-- 管理者: システム管理リンク -->
      {isAdmin && (
        <a
          href="/admin"
          class="hidden sm:flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs font-medium transition-all hover:shadow-sm no-underline"
          style="
            border-color: oklch(0.55 0.21 250 / 0.3);
            background: oklch(0.55 0.21 250 / 0.06);
            color: var(--color-primary-500);
          "
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.07 4.93l-1.41 1.41M5.34 18.66l-1.41 1.41M20.49 12H22M2 12h1.51M19.07 19.07l-1.41-1.41M5.34 5.34 3.93 3.93M12 20.49V22M12 2v1.51"></path>
          </svg>
          システム管理
        </a>
        <!-- モバイル用: アイコンのみ -->
        <a
          href="/admin"
          class="sm:hidden nav-btn"
          title="システム管理"
          aria-label="システム管理"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.07 4.93l-1.41 1.41M5.34 18.66l-1.41 1.41M20.49 12H22M2 12h1.51M19.07 19.07l-1.41-1.41M5.34 5.34 3.93 3.93M12 20.49V22M12 2v1.51"></path>
          </svg>
        </a>
      )}

      <!-- ユーザーアバター + 名前 -->
      <div class="flex items-center gap-2">
        <div
          class="flex h-8 w-8 items-center justify-center rounded-full text-sm font-semibold text-white"
          style="background: linear-gradient(135deg, oklch(0.55 0.21 250), oklch(0.65 0.18 280));"
        >
          {memberName.charAt(0)}
        </div>
        <span
          class="hidden text-sm font-medium sm:inline"
          style="color: var(--theme-text-secondary);"
        >
          {memberName}
        </span>
      </div>

      <!-- ログアウトボタン -->
      <button
        id="logout-btn"
        class="rounded-lg border px-3 py-1.5 text-xs font-medium transition-all hover:shadow-sm"
        style="
          border-color: var(--theme-card-border);
          color: var(--theme-text-secondary);
          background: transparent;
        "
      >
        ログアウト
      </button>
    </div>
  </div>
</header>

<script>
  import { createBrowserClient } from '@supabase/ssr';

  // ── テーマ切替 ──
  const themeBtn = document.getElementById('theme-toggle-btn');
  const iconMoon = document.getElementById('icon-moon');
  const iconSun  = document.getElementById('icon-sun');

  function syncThemeIcons() {
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    if (iconMoon && iconSun) {
      iconMoon.classList.toggle('hidden', current === 'dark');
      iconSun.classList.toggle('hidden',  current === 'light');
    }
  }

  syncThemeIcons();

  themeBtn?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    const next = current === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    syncThemeIcons();
  });

  // ── ログアウト ──
  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    const supabase = createBrowserClient(
      (window as any).__SUPABASE_URL__,
      (window as any).__SUPABASE_ANON_KEY__
    );
    await supabase.auth.signOut();
    window.location.href = '/login';
  });
</script>
