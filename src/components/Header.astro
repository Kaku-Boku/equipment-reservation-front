---
/**
 * ヘッダーコンポーネント
 *
 * - アプリタイトル
 * - ログインユーザー名
 * - ログアウトボタン
 */
interface Props {
  memberName: string;
}

const { memberName } = Astro.props;
---

<header
  id="app-header"
  class="sticky top-0 z-50 border-b border-surface-800/50 bg-surface-950/80 backdrop-blur-xl"
>
  <div class="mx-auto flex h-14 max-w-screen-2xl items-center justify-between px-4 sm:px-6">
    <!-- アプリタイトル -->
    <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight text-surface-50 no-underline">
      <svg class="h-6 w-6 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      <span class="hidden sm:inline">設備予約</span>
    </a>

    <!-- ユーザー情報 & ログアウト -->
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary-500/20 text-sm font-medium text-primary-300">
          {memberName.charAt(0)}
        </div>
        <span class="hidden text-sm font-medium text-surface-300 sm:inline">{memberName}</span>
      </div>
      <button
        id="logout-btn"
        class="rounded-lg border border-surface-700 px-3 py-1.5 text-xs font-medium text-surface-400 transition-all hover:border-surface-500 hover:bg-surface-800 hover:text-surface-200"
      >
        ログアウト
      </button>
    </div>
  </div>
</header>

<script>
  import { createBrowserClient } from '@supabase/ssr';

  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    const supabase = createBrowserClient(
      (window as any).__SUPABASE_URL__,
      (window as any).__SUPABASE_ANON_KEY__
    );
    await supabase.auth.signOut();
    window.location.href = '/login';
  });
</script>
