---
/**
 * ログインページ
 *
 * Pre-Check フロー:
 * 1. メアド入力 →「次へ」ボタン
 * 2. /api/pre-check で members テーブルの存在チェック
 * 3. 存在する場合のみ supabase.auth.signInWithOAuth() を発火
 * 4. 存在しなければエラー表示（Google OAuthの枠消費を防止）
 */
import Layout from "../layouts/Layout.astro";
import { SUPABASE_CONFIG } from "../lib/supabase";

// ログイン済みなら / にリダイレクト（ミドルウェアでも行うが安全策）
console.log('[login.astro] Page started. Session:', Astro.locals.session ? 'exists' : 'none');
if (Astro.locals.session) {
  console.log('[login.astro] Redirecting to /');
  return Astro.redirect("/");
}

const authError = Astro.url.searchParams.get("error");
---

<Layout title="ログイン | 設備予約" showHeader={false}>
  <div class="flex min-h-dvh items-center justify-center px-4">
    <div class="w-full max-w-md animate-fade-in">

      <!-- ロゴ & タイトル -->
      <div class="mb-8 text-center">
        <div
          class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl"
          style="background: oklch(0.55 0.21 250 / 0.1);"
        >
          <svg
            class="h-8 w-8 text-primary-500"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight" style="color: var(--theme-text);">
          設備予約
        </h1>
        <p class="mt-2 text-sm" style="color: var(--theme-text-secondary);">
          社内メールアドレスを入力してログイン
        </p>
      </div>

      <!-- ログインフォーム -->
      <div class="card p-6">
        <form id="login-form" autocomplete="on">
          <div class="space-y-4">
            <div>
              <label
                for="email-input"
                class="form-label"
              >
                メールアドレス
              </label>
              <input
                id="email-input"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="your-name@company.com"
                class="form-input"
              />
            </div>
          </div>

          <!-- エラー表示 -->
          <div
            id="error-message"
            class="mt-3 hidden rounded-lg px-4 py-3 text-sm font-medium"
            style="background: oklch(0.62 0.22 25 / 0.08); color: var(--color-danger-500); border: 1px solid oklch(0.62 0.22 25 / 0.2);"
          >
          </div>

          {
            authError && (
              <div
                class="mt-3 rounded-lg px-4 py-3 text-sm font-medium"
                style="background: oklch(0.62 0.22 25 / 0.08); color: var(--color-danger-500); border: 1px solid oklch(0.62 0.22 25 / 0.2);"
              >
                認証に失敗しました。もう一度お試しください。
              </div>
            )
          }

          <!-- 次へボタン -->
          <button
            id="submit-btn"
            type="submit"
            class="mt-6 w-full rounded-xl px-4 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-primary-400/50 disabled:cursor-not-allowed disabled:opacity-50"
            style="background: linear-gradient(135deg, oklch(0.55 0.21 250), oklch(0.50 0.19 260)); box-shadow: 0 4px 14px oklch(0.55 0.21 250 / 0.3);"
          >
            <span id="btn-text">次へ</span>
            <span id="btn-loading" class="hidden">
              <svg
                class="inline h-5 w-5 animate-spin"
                viewBox="0 0 24 24"
                fill="none"
              >
                <circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"></circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                ></path>
              </svg>
              確認中...
            </span>
          </button>
        </form>
      </div>

      <p class="mt-6 text-center text-xs" style="color: var(--theme-text-secondary);">
        ※ 社内メンバーのみログイン可能です
      </p>
    </div>
  </div>

  <!-- Supabase 設定のクライアント公開 -->
  <script
    define:vars={{
      supabaseUrl: SUPABASE_CONFIG.url,
      supabaseKey: SUPABASE_CONFIG.anonKey,
    }}
  >
    window.__SUPABASE_URL__ = supabaseUrl;
    window.__SUPABASE_ANON_KEY__ = supabaseKey;
  </script>

  <script>
    import { createBrowserClient } from "@supabase/ssr";

    const form = document.getElementById("login-form") as HTMLFormElement;
    const emailInput = document.getElementById("email-input") as HTMLInputElement;
    const errorDiv = document.getElementById("error-message") as HTMLDivElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const btnText = document.getElementById("btn-text") as HTMLSpanElement;
    const btnLoading = document.getElementById("btn-loading") as HTMLSpanElement;

    /** エラーメッセージを表示 */
    function showError(message: string) {
      errorDiv.textContent = message;
      errorDiv.classList.remove("hidden");
    }

    /** エラーメッセージを非表示 */
    function hideError() {
      errorDiv.classList.add("hidden");
    }

    /** ローディング状態の切替 */
    function setLoading(loading: boolean) {
      submitBtn.disabled = loading;
      btnText.classList.toggle("hidden", loading);
      btnLoading.classList.toggle("hidden", !loading);
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      hideError();

      const email = emailInput.value.trim().toLowerCase();
      if (!email) {
        showError("メールアドレスを入力してください。");
        return;
      }

      setLoading(true);

      try {
        // Step 1: メアドの存在確認（Pre-Check）
        const res = await fetch("/api/pre-check", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();

        if (!data.ok) {
          showError(data.message || "エラーが発生しました。");
          setLoading(false);
          return;
        }

        // Step 2: Pre-Check OK → Google OAuth 発火
        // 【重要】createBrowserClient を使用すること。
        // PKCE の code_verifier を Cookie に保存するため、
        // サーバーサイドの /auth/callback でも読み取り可能。
        const supabase = createBrowserClient(
          (window as any).__SUPABASE_URL__,
          (window as any).__SUPABASE_ANON_KEY__,
        );

        const { error } = await supabase.auth.signInWithOAuth({
          provider: "google",
          options: {
            redirectTo: `${window.location.origin}/auth/callback`,
            queryParams: {
              prompt: "consent",
              access_type: "offline",
              login_hint: email,
            },
            scopes:
              "openid email profile https://www.googleapis.com/auth/calendar.events",
          },
        });

        if (error) {
          showError("認証の開始に失敗しました。もう一度お試しください。");
          setLoading(false);
        }
        // OAuth リダイレクトが発生するため、ここで処理は終了
      } catch (err) {
        showError("通信エラーが発生しました。ネットワークを確認してください。");
        setLoading(false);
      }
    });
  </script>
</Layout>
