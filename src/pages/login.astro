---
/**
 * ログインページ
 *
 * Pre-Checkフロー:
 * 1. メアド入力 → 「次へ」ボタン
 * 2. /api/pre-check で members テーブルの存在チェック
 * 3. 存在する場合のみ supabase.auth.signInWithOAuth() を発火
 * 4. 存在しなければエラー表示
 */
import Layout from "../layouts/Layout.astro";
import { SUPABASE_CONFIG } from "../lib/supabase";

// すでにログイン済みなら / にリダイレクト（ミドルウェアでも行うが安全策）
if (Astro.locals.session) {
  return Astro.redirect("/");
}

const authError = Astro.url.searchParams.get("error");
---

<Layout title="ログイン | 設備予約" showHeader={false}>
  <div class="flex min-h-dvh items-center justify-center px-4">
    <div class="w-full max-w-md animate-fade-in">
      <!-- ロゴ & タイトル -->
      <div class="mb-8 text-center">
        <div
          class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-500/15"
        >
          <svg
            class="h-8 w-8 text-primary-400"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight text-surface-50">
          設備予約
        </h1>
        <p class="mt-2 text-sm text-surface-400">
          社内メールアドレスを入力してログイン
        </p>
      </div>

      <!-- ログインフォーム -->
      <div
        class="rounded-2xl border border-surface-800/60 bg-surface-900/50 p-6 shadow-xl backdrop-blur"
      >
        <form id="login-form" autocomplete="on">
          <div class="space-y-4">
            <div>
              <label
                for="email-input"
                class="mb-1.5 block text-sm font-medium text-surface-300"
              >
                メールアドレス
              </label>
              <input
                id="email-input"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="your-name@company.com"
                class="w-full rounded-xl border border-surface-700 bg-surface-800/50 px-4 py-3 text-sm text-surface-100 placeholder-surface-500 transition-all focus:border-primary-400 focus:outline-none focus:ring-2 focus:ring-primary-400/30"
              />
            </div>
          </div>

          <!-- エラー表示 -->
          <div
            id="error-message"
            class="mt-3 hidden rounded-lg bg-danger-500/10 p-3 text-sm text-danger-400"
          >
          </div>

          {
            authError && (
              <div class="mt-3 rounded-lg bg-danger-500/10 p-3 text-sm text-danger-400">
                認証に失敗しました。もう一度お試しください。
              </div>
            )
          }

          <!-- 次へボタン -->
          <button
            id="submit-btn"
            type="submit"
            class="mt-6 w-full rounded-xl bg-primary-500 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-400 hover:shadow-primary-400/30 focus:outline-none focus:ring-2 focus:ring-primary-400/50 disabled:cursor-not-allowed disabled:opacity-50"
          >
            <span id="btn-text">次へ</span>
            <span id="btn-loading" class="hidden">
              <svg
                class="inline h-5 w-5 animate-spin"
                viewBox="0 0 24 24"
                fill="none"
              >
                <circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"></circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                ></path>
              </svg>
              確認中...
            </span>
          </button>
        </form>
      </div>

      <p class="mt-6 text-center text-xs text-surface-500">
        ※ 社内メンバーのみログイン可能です
      </p>
    </div>
  </div>

  <!-- Supabase 設定をクライアントに渡す -->
  <script
    define:vars={{
      supabaseUrl: SUPABASE_CONFIG.url,
      supabaseKey: SUPABASE_CONFIG.anonKey,
    }}
  >
    window.__SUPABASE_URL__ = supabaseUrl;
    window.__SUPABASE_ANON_KEY__ = supabaseKey;
  </script>

  <script>
    import { createBrowserClient } from "@supabase/ssr";

    const form = document.getElementById("login-form") as HTMLFormElement;
    const emailInput = document.getElementById(
      "email-input",
    ) as HTMLInputElement;
    const errorDiv = document.getElementById("error-message") as HTMLDivElement;
    const submitBtn = document.getElementById(
      "submit-btn",
    ) as HTMLButtonElement;
    const btnText = document.getElementById("btn-text") as HTMLSpanElement;
    const btnLoading = document.getElementById(
      "btn-loading",
    ) as HTMLSpanElement;

    function showError(message: string) {
      errorDiv.textContent = message;
      errorDiv.classList.remove("hidden");
    }

    function hideError() {
      errorDiv.classList.add("hidden");
    }

    function setLoading(loading: boolean) {
      submitBtn.disabled = loading;
      btnText.classList.toggle("hidden", loading);
      btnLoading.classList.toggle("hidden", !loading);
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      hideError();

      const email = emailInput.value.trim().toLowerCase();
      if (!email) {
        showError("メールアドレスを入力してください。");
        return;
      }

      setLoading(true);

      try {
        // Step 1: Pre-check - メアドの存在確認
        const res = await fetch("/api/pre-check", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();

        if (!data.ok) {
          showError(data.message || "エラーが発生しました。");
          setLoading(false);
          return;
        }

        // Step 2: Pre-check OK → Google OAuth 発火
        // 【重要】createBrowserClient を使用すること。
        // createBrowserClient は PKCE の code_verifier を Cookie に保存するため、
        // サーバーサイドの /auth/callback でも読み取り可能。
        // 素の createClient は localStorage に保存するため、サーバー側で読み取れず
        // exchangeCodeForSession() が失敗する。
        const supabase = createBrowserClient(
          (window as any).__SUPABASE_URL__,
          (window as any).__SUPABASE_ANON_KEY__,
        );

        const { error } = await supabase.auth.signInWithOAuth({
          provider: "google",
          options: {
            redirectTo: `${window.location.origin}/auth/callback`,
            queryParams: {
              prompt: "consent",
              access_type: "offline",
              login_hint: email,
            },
            // scopes: 'https://www.googleapis.com/auth/calendar.events',
            scopes:
              "openid email profile https://www.googleapis.com/auth/calendar.events",
          },
        });

        if (error) {
          showError("認証の開始に失敗しました。もう一度お試しください。");
          setLoading(false);
        }
        // OAuth リダイレクトが発生するため、ここで処理は終了
      } catch (err) {
        showError("通信エラーが発生しました。ネットワークを確認してください。");
        setLoading(false);
      }
    });
  </script>
</Layout>
