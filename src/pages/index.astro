---
/**
 * メインページ（設備予約ダッシュボード）
 *
 * SSR で初期データを一括フェッチし、Preact の ReservationApp に
 * ハイドレーション用データとして渡す。
 *
 * フェッチ範囲: 先月1日 〜 2ヶ月後の末日
 * → 初期表示で通信ゼロ、月移動時に必要なら追加取得
 */
import Layout from "../layouts/Layout.astro";
import { SUPABASE_CONFIG } from "../lib/supabase";
import ReservationApp from "../components/ReservationApp";

const { supabase, member } = Astro.locals;
console.log('[index.astro] Page started. Member:', member?.name);

if (!supabase) {
  console.error('[index.astro] Supabase client is missing in Astro.locals!');
}

// ── 初期データの取得範囲を算出 ──
const today = new Date();
const initialStart = new Date(
  today.getFullYear(),
  today.getMonth() - 1,
  1,
).toISOString();
const initialEnd = new Date(
  today.getFullYear(),
  today.getMonth() + 3,
  0,
).toISOString();

// ── サーバーサイドで一括フェッチ ──

// 予約データ（JOIN 付き）
const { data: initialReservations } = await supabase
  .from("reservations")
  .select(
    "*, facilities:facility_id (id, name), created_by_member:created_by (id, name)",
  )
  .gte("start_time", initialStart)
  .lte("end_time", initialEnd)
  .order("start_time", { ascending: true });

// 設備マスタ
const { data: facilities } = await supabase
  .from("facilities")
  .select("id, name")
  .eq("status", "active")
  .order("name");

// メンバー一覧（参加者選択用）
const { data: members, error: membersError } = await supabase
  .from("members")
  .select("id, name, email")
  .eq("status", "active")
  .order("name");

console.log('[index.astro] Data fetch complete:', {
  reservationsCount: initialReservations?.length || 0,
  facilitiesCount: facilities?.length || 0,
  membersCount: members?.length || 0,
  hasErrors: Boolean(membersError)
});
---

<Layout title="設備予約">
  <ReservationApp
    client:load
    initialReservations={initialReservations || []}
    initialLoadedRange={{ start: initialStart, end: initialEnd }}
    initialFacilities={facilities || []}
    initialMembers={members || []}
    currentMember={member}
    supabaseUrl={SUPABASE_CONFIG.url}
    supabaseKey={SUPABASE_CONFIG.anonKey}
  />
</Layout>
